aws {
    region = 'us-east-2'
    batch {
        volumes = '/usr/local/bin:/aws-cli-host/bin:ro'
        jobRole = 'arn:aws:iam::512431263418:role/BatchJobRole'
        cliPath = '/usr/local/bin/aws'
    }
}


params {
    run               = null
    analysis          = null
    dev               = false
    number_of_inputs  = 2
    chr               = "chr22"
    if (params.dev) {
           params.path_s3 = "seqwell-dev/analysis"
         } else {
           params.path_s3 = "seqwell-analysis"
        }
}


docker {
    enabled = true
}



process {
    
    executor = 'awsbatch'
    queue = 'spot_low_priority'

    withName: get_chr {
        memory = '15.0G'
        cpus = 4
        container = 'quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
        jobDefinition = 'nextflow-batch-default'
    }

    
}