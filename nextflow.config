aws {
    region = 'us-east-2'
    batch {
        cliPath = '/usr/local/bin/aws'
        jobRole = 'arn:aws:iam::512431263418:role/BatchJobRole'
    }
}


params {
    run               = null
    analysis          = null
    dev               = false
    number_of_inputs  = 2
    chr               = "chr22"
}


docker {
    enabled = true
}



process {
    jobDefinition = 'nextflow-batch-default'
    executor = 'awsbatch'
    queue = 'spot_low_priority'

    withName: get_chr {
        memory = '15.0G'
        cpus = 4
        container = 'quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
    }

    
}